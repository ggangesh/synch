{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/.turbo",
      "!**/coverage",
      "!**/.pnpm-store",
      "!**/target",
      "!**/*.tsbuildinfo",
      "!**/apps/obsidian-plugin/main.js",
      "!**/apps/api/worker-configuration.d.ts",
      "!**/pnpm-lock.yaml",
      "!**/Cargo.lock",
      "!**/*.astro",
      "!**/.vscode",
      "!**/drizzle/**/*.json",
      "!**/.env*",
      "!**/docs"
    ]
  }
}

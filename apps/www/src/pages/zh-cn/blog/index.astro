---
import { getCollection } from "astro:content";
import BlogIndexPage from "../../../components/BlogIndexPage.astro";
import { isLocaleEntry } from "../../../i18n";

const posts = await getCollection("blog", ({ id, data }) => {
  const visible = import.meta.env.PROD ? data.draft !== true : true;
  return visible && isLocaleEntry(id, "zh-cn");
});
---

<BlogIndexPage locale="zh-cn" posts={posts} />

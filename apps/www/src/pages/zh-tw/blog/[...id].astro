---
import { getCollection, render } from "astro:content";
import BlogPostPage from "../../../components/BlogPostPage.astro";
import { blogSlug, isLocaleEntry } from "../../../i18n";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ id, data }) => {
    const visible = import.meta.env.PROD ? data.draft !== true : true;
    return visible && isLocaleEntry(id, "zh-tw");
  });

  return posts.map((post) => ({
    params: { id: blogSlug(post.id, "zh-tw") },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BlogPostPage Content={Content} locale="zh-tw" post={post} />

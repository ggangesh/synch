---
import Footer from "./Footer.astro";
import Header from "./Header.astro";
import Layout from "../layouts/Layout.astro";
import { ui, localizedPath, type Locale } from "../i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = ui[locale].home;
const repositoryUrl = "https://github.com/hjinco/synch";
const koDemoPlaybackId = "X02Xss3kvaRlmCjOmB00zCoKNnHZdPzqpTZqggJ301PMVk";
const defaultDemoPlaybackId =
  "wLFfexVomR006ejrrI0202jexidCGpEXbzuf801AKMlPh024";
const demoPlaybackId =
  locale === "ko" ? koDemoPlaybackId : defaultDemoPlaybackId;
const selfHostingHref = localizedPath(locale, "/self-hosting");
const apiUrl = import.meta.env.PUBLIC_API_URL || "";
const authBaseUrl = apiUrl || Astro.url.origin;
const vaultsUrl = new URL("/vaults", authBaseUrl);
vaultsUrl.searchParams.set("lang", locale);
const signupUrl = new URL("/signup", authBaseUrl);
signupUrl.searchParams.set("return_to", vaultsUrl.toString());
signupUrl.searchParams.set("lang", locale);
---

<Layout locale={locale}>
  <script is:inline src="https://cdn.jsdelivr.net/npm/@mux/mux-player" defer
  ></script>

  <div class="max-w-2xl mx-auto px-6 w-full flex-1 flex flex-col">
    <Header locale={locale} />

    <main class="flex-1 flex flex-col justify-center py-24">
      <div class="space-y-6">
        <h1 class="text-2xl sm:text-3xl text-zinc-200 tracking-tight">
          {t.heroTitle[0]}<br />{t.heroTitle[1]}
        </h1>

        <p class="max-w-md leading-relaxed text-zinc-500">
          {t.heroBody}
        </p>

        <div class="flex items-center gap-4 pt-4 text-xs">
          <a
            href={signupUrl.toString()}
            class="px-4 py-2 bg-zinc-800 text-zinc-200 hover:bg-zinc-700 rounded transition-colors"
          >
            {t.getStarted}
          </a>
          <a
            href={repositoryUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="px-4 py-2 bg-transparent text-zinc-400 border border-zinc-800 hover:border-zinc-700 hover:text-zinc-300 rounded transition-all"
          >
            {t.viewSource}
          </a>
        </div>

        <div class="pt-8">
          <mux-player
            playback-id={demoPlaybackId}
            title="Synch demo video"
            metadata-video-id="synch-landing-demo"
            metadata-video-title="Synch landing page demo"
            autoplay="muted"
            muted
            loop
            playsinline
            class="aspect-video w-full rounded-md border overflow-hidden border-zinc-800/80 bg-zinc-950 shadow-2xl shadow-black/30"
            style="--controls: none; --media-object-fit: cover;"></mux-player>
        </div>
      </div>

      <div class="grid sm:grid-cols-2 gap-12 mt-32">
        {
          t.features.map((feature) => (
            <div class="space-y-3">
              <div class="w-8 h-px bg-zinc-800" />
              <h3 class="text-zinc-300 font-normal">{feature.title}</h3>
              <p class="text-zinc-500 leading-relaxed">{feature.body}</p>
            </div>
          ))
        }
      </div>

      <div class="mt-32 space-y-6">
        <div class="w-8 h-px bg-zinc-800"></div>
        <h2 class="text-xl text-zinc-300 font-normal">{t.installTitle}</h2>
        <div class="space-y-6 text-zinc-500 leading-relaxed">
          <p>{t.installIntro}</p>

          <ol class="space-y-3 list-decimal list-inside marker:text-zinc-700">
            {
              t.installSteps.map((step) => (
                <li>
                  {step.length === 1 ? (
                    <>{step[0]} </>
                  ) : (
                    <>
                      {step[0] && <>{step[0]}</>}{" "}
                      <span class="text-zinc-300">{step[1]}</span>
                      {step[2]}
                    </>
                  )}
                </li>
              ))
            }
          </ol>
        </div>
      </div>

      <div class="mt-32 space-y-6">
        <div class="w-8 h-px bg-zinc-800"></div>
        <div class="max-w-xl space-y-4">
          <h2 class="text-xl text-zinc-300 font-normal">
            {t.selfHosting.title}
          </h2>
          <p class="text-zinc-500 leading-relaxed">{t.selfHosting.body}</p>
          <a
            href={selfHostingHref}
            class="inline-flex items-center rounded border border-zinc-800 px-4 py-2 text-xs text-zinc-300 transition-all hover:border-zinc-700 hover:bg-zinc-900/60 hover:text-zinc-200"
          >
            {t.selfHosting.link}
          </a>
        </div>
      </div>

      {
        t.featuredPosts.length > 0 && (
          <div class="mt-32 space-y-6">
            <div class="w-8 h-px bg-zinc-800" />
            <h2 class="text-xl text-zinc-300 font-normal">{t.featuredTitle}</h2>
            <div class="grid sm:grid-cols-2 gap-6 pt-2">
              {t.featuredPosts.map((post) => (
                <a
                  href={localizedPath(locale, post.href)}
                  class="group block p-6 rounded-md border border-zinc-800/50 bg-zinc-900/20 hover:bg-zinc-800/50 hover:border-zinc-700/50 transition-all"
                >
                  <h3 class="text-zinc-300 font-medium mb-3 group-hover:text-zinc-200">
                    {post.title}
                  </h3>
                  <p class="text-sm text-zinc-500 leading-relaxed">
                    {post.body}
                  </p>
                </a>
              ))}
            </div>
          </div>
        )
      }
    </main>

    <Footer locale={locale} />
  </div>
</Layout>
